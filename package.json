{
  "name": "oh-my-tang-dynasty",
  "version": "0.1.0",
  "description": "三省六部制 · Tang Dynasty Multi-Agent Orchestration Plugin for OpenCode",
  "type": "module",
  "main": "dist/plugin.js",
  "module": "src/plugin.ts",
  "scripts": {
    "build": "bun build ./src/index.ts ./src/plugin.ts --outdir ./dist --target node",
    "ci": "bun x tsc --noEmit && python3 -m py_compile scripts/opencode-clean-regression.py && bun test && bun run build",
    "dev": "bun build ./src/index.ts ./src/plugin.ts --outdir ./dist --target node --watch",
    "test": "bun test",
    "test:opencode-clean-regression:live": "RUN_OPENCODE_CLEAN_REGRESSION=1 bun test src/opencode-integration.test.ts -t \"opencode can execute the clean-env Tang regression flow end-to-end\"",
    "typecheck": "bun x tsc --noEmit"
  },
  "exports": {
    ".": {
      "bun": "./src/plugin.ts",
      "import": "./dist/plugin.js",
      "default": "./dist/plugin.js"
    },
    "./lib": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/*.ts",
    "src/agents/*.ts",
    "!src/*.test.ts",
    "!src/test-fixtures"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.21",
    "@opencode-ai/sdk": "^1.2.21",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "bun-types": "latest",
    "typescript": "^5.8.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/L4ntern0/oh-my-tang.git"
  },
  "bugs": {
    "url": "https://github.com/L4ntern0/oh-my-tang/issues"
  },
  "homepage": "https://github.com/L4ntern0/oh-my-tang#readme",
  "keywords": [
    "opencode",
    "plugin",
    "multi-agent",
    "orchestration",
    "tang-dynasty",
    "三省六部制"
  ]
}
